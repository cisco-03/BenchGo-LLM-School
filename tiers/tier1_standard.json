      "id": "math",
      "label": "Maths : Aire",
      "evaluations": [
        {
          "type": "exec",
          "description": "Rectangle",
          "setup": "",
          "call": "aireRectangle(5, 2)",
          "assert": "result === 10"
        }
      ],
      "points": 8
    },
    {
      "id": "francais",
