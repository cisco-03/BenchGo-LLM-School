      "id": "math",
      "label": "Maths : Pythagore",
      "evaluations": [
        {
          "type": "exec",
          "description": "3,4 -> 5",
          "setup": "",
          "call": "pythagore(3, 4)",
          "assert": "result === 5"
        }
      ],
      "points": 8
    },
