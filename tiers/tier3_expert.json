        {
          "type": "exec",
          "description": "Fusion simple",
          "setup": "",
          "call": "fusionnerConfig({ a: 1 }, { b: 2 })",
          "assert": "result.a === 1 && result.b === 2"
        },
        {
          "type": "exec",
          "description": "Fusion profonde",
          "setup": "",
          "call": "fusionnerConfig({ a: { x: 1 } }, { a: { y: 2 } })",
          "assert": "result.a.x === 1 && result.a.y === 2"
        },
        {
          "type": "exec",
          "description": "Anti pollution",
          "setup": "",
          "call": "(function() { fusionnerConfig({}, JSON.parse(\"{\\\"__proto__\\\":{\\\"polluted\\\":true}}\")); return ({}).polluted; })()",
          "assert": "result === undefined"
        }
      ],
      "points": 8
